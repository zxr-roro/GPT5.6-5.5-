{
  "platform": "kali-linux",
  "targetVersion": "2026.1",
  "kernel": "6.18",
  "note": "Kali 2026.1 专供版 manifest。基于 2025.4 + 2026.1 新增工具优化。大量工具已预装，bootstrap 主要处理非预装工具和 MCP 注册。",
  "kaliNewTools2026_1": [
    "adaptixc2 — 后渗透与对抗模拟框架 (apt install adaptixc2)",
    "atomic-operator — Atomic Red Team 测试执行器 (apt install atomic-operator)",
    "fluxion — WiFi 社工审计工具 (apt install fluxion)",
    "gef — GDB 增强调试框架 (apt install gef)",
    "metasploitmcp — Metasploit MCP Server (apt install metasploitmcp)",
    "sstimap — SSTI 自动检测工具 (apt install sstimap)",
    "wpprobe — WordPress 插件枚举 (apt install wpprobe)",
    "xsstrike — 高级 XSS 扫描器 (apt install xsstrike)"
  ],
  "kaliNewTools2025_4": [
    "bpf-linker — BPF 静态链接器 (apt install bpf-linker)",
    "evil-winrm-py — Python 版 WinRM 远程执行 (apt install evil-winrm-py)",
    "hexstrike-ai — AI MCP 安全自动化平台 (apt install hexstrike-ai)"
  ],
  "kaliNativeMCP": [
    "mcp-kali-server — Kali 官方 MCP Server，连接 AI 到 Kali 终端 (apt install mcp-kali-server, port 5000)",
    "metasploitmcp — Metasploit MCP Server (apt install metasploitmcp, port 8085)",
    "hexstrike-ai — 150+ 安全工具 MCP 自动化 (apt install hexstrike-ai)"
  ],
  "capabilities": [
    {
      "name": "jadx",
      "bootstrapKind": "github-release-tar",
      "repo": "skylot/jadx",
      "assetRegex": "^jadx-[0-9].*\\.zip$",
      "installDir": "$HOME/tools/jadx",
      "docsUrl": "https://github.com/skylot/jadx",
      "canAutoInstall": true,
      "verifyCommand": "jadx",
      "kaliNote": "Kali 无预装，从 GitHub Release 下载"
    },
    {
      "name": "apktool",
      "bootstrapKind": "apt-package",
      "aptPackage": "apktool",
      "fallbackKind": "github-release-jar",
      "repo": "iBotPeaches/Apktool",
      "assetRegex": "^apktool_.*\\.jar$",
      "installDir": "$HOME/tools/apktool",
      "docsUrl": "https://apktool.org/",
      "canAutoInstall": true,
      "verifyCommand": "apktool",
      "kaliNote": "apt install apktool 即可，版本较旧时可从 GitHub 下载最新"
    },
    {
      "name": "frida",
      "bootstrapKind": "pip-package",
      "pipPackage": "frida-tools",
      "docsUrl": "https://frida.re/",
      "canAutoInstall": true,
      "verifyCommand": "frida",
      "kaliNote": "pip3 install frida-tools 或 apt install python3-frida-tools"
    },
    {
      "name": "frida-ps",
      "bootstrapKind": "pip-package",
      "pipPackage": "frida-tools",
      "docsUrl": "https://frida.re/",
      "canAutoInstall": true,
      "verifyCommand": "frida-ps"
    },
    {
      "name": "idalib-mcp",
      "bootstrapKind": "pip-package",
      "pipPackage": "ida-pro-mcp",
      "pipSource": "git+https://github.com/mrexodia/ida-pro-mcp.git",
      "docsUrl": "https://github.com/mrexodia/ida-pro-mcp",
      "canAutoInstall": true,
      "verifyCommand": "ida-pro-mcp",
      "postInstallSteps": [
        "ida-pro-mcp --install (选择 Streamable HTTP + Global)",
        "重启 IDA Pro 使插件生效",
        "IDA 打开文件后 MCP 自动监听 127.0.0.1:13337"
      ],
      "kaliNote": "需要 IDA Pro Linux 版本"
    },
    {
      "name": "jshookmcp",
      "bootstrapKind": "npm-mcp",
      "npmPackage": "@jshookmcp/jshook@latest",
      "mcpNames": ["jshook"],
      "mcpCommand": "npx",
      "mcpArgs": ["-y", "@jshookmcp/jshook@latest"],
      "mcpEnv": {
        "JSHOOK_BASE_PROFILE": "search"
      },
      "docsUrl": "https://github.com/vmoranv/jshookmcp",
      "canAutoInstall": true,
      "verifyCommand": "npx"
    },
    {
      "name": "anything-analyzer",
      "bootstrapKind": "local-http-mcp",
      "repoUrl": "https://github.com/Mouseww/anything-analyzer",
      "installDir": "$HOME/tools/anything-analyzer",
      "startupDirCandidates": [
        "$HOME/tools/anything-analyzer"
      ],
      "startCommand": "pnpm",
      "startArgs": ["dev"],
      "mcpNames": ["anything-analyzer", "local-mcp"],
      "mcpUrl": "http://localhost:23816/mcp",
      "servicePort": 23816,
      "docsUrl": "https://github.com/Mouseww/anything-analyzer",
      "canAutoInstall": true,
      "verificationMode": "service-or-registration"
    },
    {
      "name": "idapro",
      "bootstrapKind": "local-http-mcp",
      "dependsOn": ["idalib-mcp"],
      "mcpNames": ["idapro"],
      "mcpUrl": "http://127.0.0.1:13337/mcp",
      "servicePort": 13337,
      "servicePortRange": [13337, 13350],
      "portNote": "IDA 多实例时端口递增 (13337→13338→...)，检查 IDA Output 窗口的 [MCP] port=xxxxx 日志",
      "startScript": "$SKILL_ROOT/../kali/scripts/ida-start.sh",
      "docsUrl": "https://hex-rays.com/ida-pro/",
      "canAutoInstall": true,
      "verificationMode": "service-and-registration",
      "kaliNote": "需要 IDA Pro Linux 版，安装到 /opt/idapro/"
    },
    {
      "name": "r2",
